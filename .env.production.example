APP_NAME="E-SAKIP Kabupaten Banjarnegara"
APP_ENV=production
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://e-sakip.banjarnegarakab.go.id

APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=cache
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=admin@example.test
SUPER_ADMIN_PASSWORD=CHANGE_ME_BEFORE_SEED
SUPER_ADMIN_PHONE=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=e_sakip_bna
DB_USERNAME=e_sakip_user
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=e-sakip.banjarnegarakab.go.id
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
CACHE_STORE=redis
CACHE_PREFIX=e_sakip_bna_cache
QUEUE_CONNECTION=redis

FILESYSTEM_DISK=local
DOCUMENTS_DISK=local

# Gunakan ini bila storage dokumen memakai MinIO/S3-compatible.
# DOCUMENTS_DISK=s3
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=e-sakip-documents
# AWS_ENDPOINT=https://minio.example.go.id
# AWS_URL=
# AWS_USE_PATH_STYLE_ENDPOINT=true

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.go.id
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS="noreply@banjarnegarakab.go.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
